{
  "schemaVersion": 1,
  "policyId": "qwen3-explicit-kv-ffn-int4-protected",
  "strategy": "mixed-precision-fidelity-first",
  "layerCount": 28,
  "protectedEdgeLayerCount": 4,
  "weights": {
    "embedding": "int8",
    "lmHead": "int8",
    "norms": "fp16",
    "attentionQKO": "int8",
    "attentionV": "int8",
    "ffn": "int4"
  },
  "kvCache": "fp16",
  "structuralReduction": false,
  "int4Compression": {
    "method": "palettization",
    "mode": "uniform",
    "granularity": "per_tensor",
    "groupSize": 32,
    "enablePerChannelScale": false,
    "clusterDim": 1,
    "numKMeansWorkers": 1,
    "weightThreshold": 2048
  },
  "opNamePatterns": {
    "embedding": [
      "embed_tokens"
    ],
    "lmHead": [
      "lm_head"
    ],
    "norms": [
      "input_layernorm",
      "post_attention_layernorm",
      "q_norm",
      "k_norm",
      "norm"
    ],
    "attentionQKO": [
      "self_attn.q_proj",
      "self_attn.k_proj",
      "self_attn.o_proj"
    ],
    "attentionV": [
      "self_attn.v_proj"
    ],
    "ffn": [
      "mlp.gate_proj",
      "mlp.up_proj",
      "mlp.down_proj"
    ]
  }
}
